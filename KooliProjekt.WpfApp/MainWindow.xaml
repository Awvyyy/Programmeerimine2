<Window x:Class="KooliProjekt.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Media Library WPF" Height="450" Width="850">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 10">
            <Button Content="Load" Command="{Binding LoadCommand}" Margin="0 0 5 0" />
            <Button Content="New" Command="{Binding NewCommand}" Margin="0 0 5 0" />
            <Button Content="Save" Command="{Binding SaveCommand}" Margin="0 0 5 0" />
            <Button Content="Delete" Command="{Binding DeleteCommand}" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="True" />
            <StackPanel Grid.Column="1" Margin="10 0 0 0" DataContext="{Binding SelectedItem}">
                <TextBlock Text="Title" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Creator" />
                <TextBox Text="{Binding AuthorOrCreator, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Price" />
                <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
