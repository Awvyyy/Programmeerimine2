@model LoansIndexModel
<h1>Loans</h1>
<p><a asp-action="Create">Create new</a></p>
<form method="get"><input asp-for="Search.Keyword" name="Keyword" placeholder="Search" /><label><input asp-for="Search.OnlyOpen" name="OnlyOpen" /> Only open</label><button>Search</button></form>
<table><thead><tr><th>Media item</th><th>Borrower</th><th>Borrowed</th><th>Due</th><th>Returned</th><th></th></tr></thead><tbody>
@foreach (var item in Model.Data.Results)
{
<tr><td>@item.MediaItem?.Title</td><td>@item.Borrower?.FullName</td><td>@item.BorrowedAt.ToShortDateString()</td><td>@item.DueAt.ToShortDateString()</td><td>@item.ReturnedAt?.ToShortDateString()</td><td><a asp-action="Edit" asp-route-id="@item.Id">Edit</a> | <a asp-action="Details" asp-route-id="@item.Id">Details</a> | <a asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>
}
</tbody></table>
@(await Component.InvokeAsync<PagerViewComponent>(Model.Data))
