@{ ViewData["Title"]="Edit media item"; ViewData["Action"]="Edit"; }

@model MediaItem
<h1>@ViewData["Title"]</h1>
<form asp-action='@ViewData["Action"]'>
    <div asp-validation-summary="ModelOnly"></div>
    <input type="hidden" asp-for="Id" />
    <div><label asp-for="Title"></label><input asp-for="Title" /><span asp-validation-for="Title"></span></div>
    <div><label asp-for="AuthorOrCreator"></label><input asp-for="AuthorOrCreator" /></div>
    <div><label asp-for="MediaType"></label><select asp-for="MediaType" asp-items="Html.GetEnumSelectList<MediaType>()"></select></div>
    <div><label asp-for="ReleaseDate"></label><input asp-for="ReleaseDate" type="date" /></div>
    <div><label asp-for="Price"></label><input asp-for="Price" /></div>
    <div><label asp-for="CategoryId"></label><select asp-for="CategoryId" asp-items="ViewBag.CategoryId"></select></div>
    <div><label><input asp-for="IsAvailable" /> Available</label></div>
    <button type="submit">Save</button>
    <a asp-action="Index">Back</a>
</form>
