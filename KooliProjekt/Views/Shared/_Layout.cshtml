<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Media Library</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<header>
    <nav class="topnav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="MediaItems" asp-action="Index">Media</a>
        <a asp-controller="Categories" asp-action="Index">Categories</a>
        <a asp-controller="People" asp-action="Index">People</a>
        <a asp-controller="Loans" asp-action="Index">Loans</a>
        <a asp-controller="Reviews" asp-action="Index">Reviews</a>
        <partial name="_LoginPartial" />
    </nav>
</header>
<main class="container">@RenderBody()</main>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
